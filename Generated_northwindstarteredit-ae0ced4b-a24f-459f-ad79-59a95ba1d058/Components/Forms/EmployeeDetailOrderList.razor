@using Generated_northwindstarteredit_ae0ced4b_a24f_459f_ad79_59a95ba1d058.Models
@using Generated_northwindstarteredit_ae0ced4b_a24f_459f_ad79_59a95ba1d058.Services
@inject IOrderService OrderService

<div class="access-form employee-detail-order-list card shadow-sm">
    <div class="card-header">Employee Orders (@orders.Count)</div>
    <div class="card-body table-responsive">
        <table class="table table-sm table-striped mb-0">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Date</th>
                    <th>Customer</th>
                    <th>Status</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in orders)
                {
                    <tr>
                        <td>@order.OrderID</td>
                        <td>@order.OrderDate.ToShortDateString()</td>
                        <td>@order.CustomerName</td>
                        <td>@order.StatusName</td>
                        <td>@order.OrderTotal?.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter] public int EmployeeID { get; set; }

    private List<OrderListDto> orders = [];

    protected override async Task OnParametersSetAsync()
    {
        if (EmployeeID <= 0)
        {
            orders = [];
            return;
        }

        orders = await OrderService.GetMostRecentOrdersByEmployeeAsync(EmployeeID);
    }
}
