@page "/main-menu-product-list"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using Generated_northwindstarteredit_ae0ced4b_a24f_459f_ad79_59a95ba1d058.Models
@using Generated_northwindstarteredit_ae0ced4b_a24f_459f_ad79_59a95ba1d058.Services
@inject IReportService ReportService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="card shadow-sm access-form access-main-menu-product-list">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Products Summary</span>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-primary" tabindex="1" @onclick="ExportCsvAsync">Export to File</button>
            <button class="btn btn-sm btn-primary" tabindex="2" @onclick='() => Navigation.NavigateTo("/product-detail")'>Add Product</button>
        </div>
    </div>
    <div class="card-body table-responsive">
        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="alert alert-info py-2">@statusMessage</div>
        }

        <table class="table table-sm table-striped mb-0">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Unit Price</th>
                    <th>Qty Sold</th>
                    <th>Sold This Week</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in rows)
                {
                    <tr>
                        <td>@row.ProductCode</td>
                        <td>@row.ProductName</td>
                        <td>@row.ProductDescription</td>
                        <td>@row.UnitPrice.ToString("C")</td>
                        <td>@row.QtySold</td>
                        <td>@row.SoldThisWeek</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<ProductSummaryDto> rows = [];
    private string? statusMessage;
    private IJSObjectReference? module;

    protected override async Task OnInitializedAsync()
    {
        rows = await ReportService.GetProductsSummaryAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/MainMenuProductList.razor.js");
        }
    }

    private async Task ExportCsvAsync()
    {
        module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/MainMenuProductList.razor.js");

        var builder = new System.Text.StringBuilder();
        builder.AppendLine("ProductID,ProductCode,ProductName,ProductDescription,UnitPrice,QtySold,SoldThisWeek");

        foreach (var row in rows)
        {
            builder.AppendLine(string.Join(",", new[]
            {
                row.ProductID.ToString(),
                EscapeCsv(row.ProductCode),
                EscapeCsv(row.ProductName),
                EscapeCsv(row.ProductDescription),
                row.UnitPrice.ToString(System.Globalization.CultureInfo.InvariantCulture),
                row.QtySold.ToString(),
                row.SoldThisWeek.ToString()
            }));
        }

        var csvBytes = System.Text.Encoding.UTF8.GetBytes(builder.ToString());
        var base64 = Convert.ToBase64String(csvBytes);
        await module.InvokeVoidAsync("downloadFile", $"products-summary-{DateTime.UtcNow:yyyyMMddHHmmss}.csv", base64);
        statusMessage = $"Exported {rows.Count} product rows.";
    }

    private static string EscapeCsv(string? value)
    {
        var safeValue = value ?? string.Empty;
        if (safeValue.Contains(',') || safeValue.Contains('"') || safeValue.Contains('\n'))
        {
            return $"\"{safeValue.Replace("\"", "\"\"")}\"";
        }

        return safeValue;
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            await module.DisposeAsync();
        }
    }
}
