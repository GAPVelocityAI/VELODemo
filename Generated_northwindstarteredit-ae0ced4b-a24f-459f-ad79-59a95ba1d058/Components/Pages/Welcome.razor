@page "/welcome"
@rendermode InteractiveServer
@using Generated_northwindstarteredit_ae0ced4b_a24f_459f_ad79_59a95ba1d058.Models
@using Generated_northwindstarteredit_ae0ced4b_a24f_459f_ad79_59a95ba1d058.Services
@inject NavigationManager Navigation

<div class="card shadow-sm access-form access-welcome">
    <div class="card-header">Welcome</div>
    <div class="card-body">
        @* TODO: Missing dedicated service method for query "Welcome". Bind welcome/about data when service is generated. *@
        <div class="alert alert-warning py-2">Welcome data query service is pending.</div>

        <h5>@(welcomeRecord.WelcomeText ?? "Welcome to Northwind")</h5>
        <p>@welcomeRecord.About</p>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" tabindex="1" @onclick='() => Navigation.NavigateTo("/main-menu")'>Continue</button>
            <button class="btn btn-outline-secondary" tabindex="2" @onclick='() => Navigation.NavigateTo("/about")'>About</button>
        </div>
    </div>
</div>

@code {
    private readonly Generated_northwindstarteredit_ae0ced4b_a24f_459f_ad79_59a95ba1d058.Models.Welcome welcomeRecord = new()
    {
        WelcomeText = "Welcome to Northwind Starter",
        About = "Use the Main Menu to manage customers, orders, products, and reports."
    };
}
