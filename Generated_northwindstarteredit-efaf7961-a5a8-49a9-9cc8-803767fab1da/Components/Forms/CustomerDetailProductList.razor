@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject IReportService ReportService

<div class="card access-form access-customer-detail-product-list">
    <div class="card-header fw-semibold">Customer Products</div>
    <div class="card-body p-0">
        @if (isLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary"></div>
                <p class="text-muted mt-2 mb-0">Loading product history...</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger m-3" role="alert">@errorMessage</div>
        }
        else if (!rows.Any())
        {
            <div class="text-center text-muted py-4">No product history found.</div>
        }
        else
        {
            <table class="table table-sm table-hover mb-0">
                <thead>
                    <tr>
                        <th>Product #</th>
                        <th>Product</th>
                        <th class="text-end">Quantity</th>
                        <th class="text-end">Orders</th>
                        <th>First Ordered</th>
                        <th>Last Ordered</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr>
                            <td>@row.ProductID</td>
                            <td>@row.ProductName</td>
                            <td class="text-end">@row.Quantity</td>
                            <td class="text-end">@row.OrderCount</td>
                            <td>@row.FirstOrdered.ToString("d")</td>
                            <td>@row.LastOrdered.ToString("d")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
    @if (!isLoading && rows.Any())
    {
        <div class="card-footer text-muted small">Products: @rows.Count</div>
    }
</div>

@code {
    [Parameter] public int CustomerID { get; set; }

    private List<CustomerProductSummaryDto> rows = new();
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        await LoadRowsAsync();
    }

    private async Task LoadRowsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var allRows = await ReportService.GetCustomerProductSummaryAsync();

            // TODO: Add IReportService.GetCustomerProductSummaryByCustomerAsync(int customerId) for server-side filtering.
            rows = CustomerID > 0
                ? allRows.Where(x => x.CustomerID == CustomerID).ToList()
                : allRows;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            rows = new();
        }
        finally
        {
            isLoading = false;
        }
    }
}
