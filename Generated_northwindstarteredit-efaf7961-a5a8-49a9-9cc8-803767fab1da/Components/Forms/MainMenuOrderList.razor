@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject IOrderService OrderService

<div class="card access-form access-main-menu-order-list">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Order List</span>
        <div class="btn-group btn-group-sm" role="group" aria-label="Order filters">
            <button class="btn @(selectedFilter == MainMenuOrderFilter.OpenOrders ? "btn-primary" : "btn-outline-primary")"
                    tabindex="0"
                    @onclick="() => ApplyFilterAsync(MainMenuOrderFilter.OpenOrders)">
                Open Orders
            </button>
            <button class="btn @(selectedFilter == MainMenuOrderFilter.RecentOrders ? "btn-primary" : "btn-outline-primary")"
                    tabindex="1"
                    @onclick="() => ApplyFilterAsync(MainMenuOrderFilter.RecentOrders)">
                Recent Orders
            </button>
            <button class="btn @(selectedFilter == MainMenuOrderFilter.MyOrders ? "btn-primary" : "btn-outline-primary")"
                    tabindex="2"
                    @onclick="() => ApplyFilterAsync(MainMenuOrderFilter.MyOrders)">
                My Orders
            </button>
        </div>
    </div>

    <div class="card-body p-0">
        @if (isLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary"></div>
                <p class="text-muted mt-2 mb-0">Loading orders...</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger m-3" role="alert">@errorMessage</div>
        }
        else if (!string.IsNullOrWhiteSpace(infoMessage))
        {
            <div class="alert alert-warning m-3" role="alert">@infoMessage</div>
        }

        @if (!isLoading)
        {
            if (!orders.Any())
            {
                <div class="text-center text-muted py-4">No orders found.</div>
            }
            else
            {
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Order Date</th>
                            <th>Shipped</th>
                            <th>Paid</th>
                            <th>Status</th>
                            <th>Employee</th>
                            <th>Customer</th>
                            <th>Notes</th>
                            <th class="text-end">Order Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in orders)
                        {
                            <tr>
                                <td>@order.OrderID</td>
                                <td>@order.OrderDate.ToString("d")</td>
                                <td>@(order.ShippedDate?.ToString("d") ?? "-")</td>
                                <td>@(order.PaidDate?.ToString("d") ?? "-")</td>
                                <td>@order.StatusName</td>
                                <td>@order.FullNameFNLN</td>
                                <td>@order.CustomerName</td>
                                <td>@order.PlainTextNotes</td>
                                <td class="text-end">@order.OrderTotal.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </div>

    @if (!isLoading && orders.Any())
    {
        <div class="card-footer d-flex justify-content-between small text-muted">
            <span>Count: @orders.Count</span>
            <span>Total: @orders.Sum(x => x.OrderTotal).ToString("C")</span>
        </div>
    }
</div>

@code {
    [Parameter] public int CurrentEmployeeId { get; set; }

    private List<OrderSummaryDto> orders = new();
    private MainMenuOrderFilter selectedFilter = MainMenuOrderFilter.OpenOrders;
    private bool isLoading = true;
    private string? errorMessage;
    private string? infoMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrdersAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (selectedFilter == MainMenuOrderFilter.MyOrders)
        {
            await LoadOrdersAsync();
        }
    }

    private async Task ApplyFilterAsync(MainMenuOrderFilter filter)
    {
        if (selectedFilter == filter)
        {
            return;
        }

        selectedFilter = filter;
        await LoadOrdersAsync();
    }

    private async Task LoadOrdersAsync()
    {
        isLoading = true;
        errorMessage = null;
        infoMessage = null;

        try
        {
            orders = selectedFilter switch
            {
                MainMenuOrderFilter.OpenOrders => await OrderService.GetOrdersAsync(),
                MainMenuOrderFilter.RecentOrders => await OrderService.GetOrdersMostRecentByOrderDateAsync(),
                MainMenuOrderFilter.MyOrders when CurrentEmployeeId > 0
                    => await OrderService.GetOrdersMostRecentByEmployeeAsync(CurrentEmployeeId),
                _ => await OrderService.GetOrdersAsync()
            };

            // TODO: Provide a resolved CurrentEmployeeId from parent/login context before selecting "My Orders".
            if (selectedFilter == MainMenuOrderFilter.MyOrders && CurrentEmployeeId <= 0)
            {
                infoMessage = "Current employee is not set. Showing all orders instead.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            orders = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private enum MainMenuOrderFilter
    {
        OpenOrders,
        RecentOrders,
        MyOrders
    }
}
