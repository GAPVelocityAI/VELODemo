@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject IOrderDetailsService OrderDetailsService
@inject IProductService ProductService

<div class="card access-form access-order-details-items">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Order Items</span>
        <button class="btn btn-sm @(showEditor ? "btn-outline-secondary" : "btn-primary")" tabindex="0" @onclick="ToggleAddNew">
            @(showEditor ? "Cancel" : "Add New")
        </button>
    </div>

    <div class="card-body">
        @if (showEditor)
        {
            <EditForm Model="editModel" OnValidSubmit="SaveItemAsync" class="border rounded p-3 mb-3">
                <DataAnnotationsValidator />

                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Product</label>
                        <InputSelect TValue="int"
                                     class="form-select"
                                     tabindex="1"
                                     Value="editModel.ProductID"
                                     ValueChanged="OnProductChangedAsync"
                                     ValueExpression="() => editModel.ProductID">
                            <option value="0">-- select product --</option>
                            @foreach (var product in products)
                            {
                                <option value="@product.ProductID">@product.ProductName</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Quantity</label>
                        <InputNumber TValue="short" class="form-control" tabindex="2" @bind-Value="editModel.Quantity" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Unit Price</label>
                        <InputNumber TValue="decimal" class="form-control" tabindex="3" @bind-Value="editModel.UnitPrice" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Line Total</label>
                        <input class="form-control" value="@GetLineTotalDisplay(editModel)" readonly tabindex="-1" />
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(formMessage))
                {
                    <div class="small text-danger mt-2">@formMessage</div>
                }

                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary" tabindex="4" disabled="@isSaving">
                        @(isSaving ? "Saving..." : "Save")
                    </button>
                    @if (isEditing)
                    {
                        <button type="button" class="btn btn-outline-secondary" tabindex="5" @onclick="StartAddNew">
                            Switch to Add New
                        </button>
                    }
                </div>
            </EditForm>
        }

        @if (isLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary"></div>
                <p class="text-muted mt-2 mb-0">Loading order items...</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger" role="alert">@errorMessage</div>
        }
        else if (!items.Any())
        {
            <div class="text-center text-muted py-4">No order items found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Product ID</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Line Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in items)
                        {
                            <tr>
                                <td>@item.ProductID</td>
                                <td class="text-end">@item.Quantity</td>
                                <td class="text-end">@item.UnitPrice.ToString("C")</td>
                                <td class="text-end">@GetLineTotal(item).ToString("C")</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" tabindex="6" @onclick="() => EditItem(item)">Edit</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="text-muted small mt-2">
                Total Price: @items.Sum(GetLineTotal).ToString("C")
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int OrderID { get; set; }

    private List<OrderDetails> items = new();
    private List<CboProductDto> products = new();
    private OrderDetails editModel = new();
    private bool showEditor;
    private bool isEditing;
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;
    private string? formMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadItemsAsync();

        if (showEditor && !isEditing)
        {
            editModel.OrderID = OrderID;
        }
    }

    private async Task LoadProductsAsync()
    {
        products = await ProductService.GetCboProductsAsync();
    }

    private async Task LoadItemsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var allItems = await OrderDetailsService.GetOrderDetailsAsync();

            // TODO: Add IOrderDetailsService.GetOrderDetailsByOrderAsync(int orderId) for server-side filtering.
            items = allItems.Where(x => x.OrderID == OrderID).OrderBy(x => x.OrderDetailID).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            items = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleAddNew()
    {
        if (showEditor)
        {
            showEditor = false;
            isEditing = false;
            formMessage = null;
            return;
        }

        StartAddNew();
    }

    private void StartAddNew()
    {
        showEditor = true;
        isEditing = false;
        formMessage = null;
        editModel = new OrderDetails
        {
            OrderID = OrderID,
            Quantity = 1
        };
    }

    private void EditItem(OrderDetails item)
    {
        showEditor = true;
        isEditing = true;
        formMessage = null;
        editModel = new OrderDetails
        {
            OrderDetailID = item.OrderDetailID,
            OrderID = item.OrderID,
            ProductID = item.ProductID,
            Quantity = item.Quantity,
            UnitPrice = item.UnitPrice,
            AddedBy = item.AddedBy,
            AddedOn = item.AddedOn,
            ModifiedBy = item.ModifiedBy,
            ModifiedOn = item.ModifiedOn,
        };
    }

    private Task OnProductChangedAsync(int productId)
    {
        editModel.ProductID = productId;

        var selected = products.FirstOrDefault(x => x.ProductID == productId);
        if (selected is not null)
        {
            editModel.UnitPrice = selected.UnitPrice;
        }

        return Task.CompletedTask;
    }

    private async Task SaveItemAsync()
    {
        formMessage = null;
        errorMessage = null;

        if (OrderID <= 0)
        {
            formMessage = "OrderID is required before saving order items.";
            return;
        }

        if (editModel.ProductID <= 0)
        {
            formMessage = "Please select a product.";
            return;
        }

        isSaving = true;

        try
        {
            editModel.OrderID = OrderID;

            if (editModel.OrderDetailID > 0)
            {
                await OrderDetailsService.UpdateAsync(editModel);
            }
            else
            {
                await OrderDetailsService.CreateAsync(editModel);
            }

            await LoadItemsAsync();
            StartAddNew();
            formMessage = "Saved.";
        }
        catch (Exception ex)
        {
            formMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private static decimal GetLineTotal(OrderDetails item) => item.Quantity * item.UnitPrice;

    private static string GetLineTotalDisplay(OrderDetails item) => GetLineTotal(item).ToString("C");
}
 GetLineTotal(item).ToString("C");
}
