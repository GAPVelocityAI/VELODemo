@page "/about"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject NorthwindstartereditEfaf7961A5A849A99Cc8803767Fab1DaDbContext Db
@inject NavigationManager Navigation

<PageTitle>About</PageTitle>

<div class="container-fluid py-3 access-form access-about">
    <h1 class="page-title mb-3">About Northwind</h1>

    <div class="card">
        <div class="card-body">
            @if (isLoading)
            {
                <div class="text-muted">Loading...</div>
            }
            else if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger" role="alert">@errorMessage</div>
            }
            else
            {
                <p class="mb-0">@aboutText</p>
            }
        </div>
        <div class="card-footer d-flex justify-content-end">
            <button type="button" class="btn btn-primary" tabindex="0" @onclick="GoBack">Close</button>
        </div>
    </div>

    @* TODO: No dedicated Welcome/About service method exists for the Welcome record source; create IWelcomeService.GetAboutAsync(). *@
</div>

@code {
    private string aboutText = "About information is not available.";
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var welcome = await Db.Welcome.FirstOrDefaultAsync();
            aboutText = string.IsNullOrWhiteSpace(welcome?.About)
                ? "About information is not available."
                : welcome.About;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/main-menu");
    }
}
