@page "/admin"
@rendermode InteractiveServer
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Components.Forms
@inject NavigationManager Navigation

<PageTitle>Admin</PageTitle>

<div class="container-fluid py-3 access-form access-admin">
    <h1 class="page-title mb-3">Administration</h1>

    <div class="card mb-3">
        <div class="card-body d-flex flex-wrap gap-2">
            <button type="button" class="btn @(selectedPanel == AdminPanel.SystemSettings ? "btn-primary" : "btn-outline-primary")" tabindex="0" @onclick="() => SelectPanel(AdminPanel.SystemSettings)">System Settings</button>
            <button type="button" class="btn @(selectedPanel == AdminPanel.InternetOrders ? "btn-primary" : "btn-outline-primary")" tabindex="1" @onclick="() => SelectPanel(AdminPanel.InternetOrders)">Internet Orders</button>
            <button type="button" class="btn @(selectedPanel == AdminPanel.ResetDates ? "btn-primary" : "btn-outline-primary")" tabindex="2" @onclick="() => SelectPanel(AdminPanel.ResetDates)">Reset Dates</button>
            <button type="button" class="btn @(selectedPanel == AdminPanel.DeleteTestData ? "btn-primary" : "btn-outline-primary")" tabindex="3" @onclick="() => SelectPanel(AdminPanel.DeleteTestData)">Delete Test Data</button>
            <button type="button" class="btn btn-outline-secondary" tabindex="4" @onclick="GoToAbout">About Northwind</button>
        </div>
    </div>

    @if (selectedPanel == AdminPanel.SystemSettings)
    {
        <AdminSystemSettings />
    }
    else if (selectedPanel == AdminPanel.InternetOrders)
    {
        <AdminInternetOrders />
    }
    else if (selectedPanel == AdminPanel.ResetDates)
    {
        <AdminResetDates />
    }
    else
    {
        <AdminDeleteTestData />
    }
</div>

@code {
    private AdminPanel selectedPanel = AdminPanel.SystemSettings;

    private void SelectPanel(AdminPanel panel)
    {
        selectedPanel = panel;
    }

    private void GoToAbout()
    {
        Navigation.NavigateTo("/about");
    }

    private enum AdminPanel
    {
        SystemSettings,
        InternetOrders,
        ResetDates,
        DeleteTestData,
    }
}
