@page "/admin-delete-test-data"
@rendermode InteractiveServer
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject IModOrdersService ModOrdersService
@inject ISystemSettingsService SystemSettingsService
@inject IJSRuntime JS

<PageTitle>Admin Delete Test Data</PageTitle>

<div class="container-fluid py-3 access-form access-admin-delete-test-data">
    <h1 class="page-title mb-3">Admin - Delete Test Data</h1>

    <div class="card border-danger">
        <div class="card-body">
            <p class="text-danger fw-semibold">This action permanently removes test data.</p>
            <p class="mb-3">Use with caution and only in non-production datasets.</p>

            <button type="button" class="btn btn-danger" tabindex="0" @onclick="RemoveTestDataAsync" disabled="@isBusy">Remove Test Data</button>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="alert alert-warning mt-3 mb-0" role="alert">@statusMessage</div>
            }
        </div>
    </div>

    @* TODO: IModOrdersService is missing a DeleteTestDataAsync workflow method for this Access action. *@
</div>

@code {
    private bool isBusy;
    private string? statusMessage;

    private async Task RemoveTestDataAsync()
    {
        statusMessage = null;

        var confirmed = await JS.InvokeAsync<bool>("confirm", "This will permanently delete test data. Continue?");
        if (!confirmed)
        {
            return;
        }

        isBusy = true;

        try
        {
            // Keep IModOrdersService in use for this workflow context; deletion method is not yet exposed.
            _ = ModOrdersService;

            var settings = await SystemSettingsService.GetSystemSettingsAsync();
            var showWelcome = settings.FirstOrDefault(x => x.SettingID == (int)Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models.Enums.SystemSettings.ShowWelcome);
            if (showWelcome is not null)
            {
                showWelcome.SettingValue = "-1";
                await SystemSettingsService.UpdateAsync(showWelcome);
            }

            statusMessage = "Delete workflow is pending service implementation. ShowWelcome setting was reset to True as a safe partial action.";
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }
}
y = false;
        }
    }
}
