@page "/admin-internet-orders"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject IModOrdersService ModOrdersService
@inject ISystemSettingsService SystemSettingsService
@inject IJSRuntime JS

<PageTitle>Admin Internet Orders</PageTitle>

<div class="container-fluid py-3 access-form access-admin-internet-orders">
    <h1 class="page-title mb-3">Admin - Internet Orders</h1>

    <div class="card">
        <div class="card-body">
            <EditForm Model="model" OnValidSubmit="CreateOrdersAsync">
                <DataAnnotationsValidator />

                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label" for="order-count">Order Count</label>
                        <InputNumber id="order-count" TValue="short" class="form-control" tabindex="0" @bind-Value="orderCount" />
                        <div class="form-text">Enter a value between 1 and 500.</div>
                    </div>
                    <div class="col-md-3 d-grid">
                        <button type="submit" class="btn btn-primary" tabindex="1" disabled="@isBusy">Create</button>
                    </div>
                    <div class="col-md-6">
                        @if (!string.IsNullOrWhiteSpace(lastResetText))
                        {
                            <div class="small text-muted">@lastResetText</div>
                        }
                    </div>
                </div>
            </EditForm>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="alert alert-info mt-3 mb-0" role="alert">@statusMessage</div>
            }
        </div>
    </div>
</div>

@code {
    private AdminInternetOrdersInput model = new();
    private short orderCount
    {
        get => model.OrderCount;
        set => model.OrderCount = value;
    }
    private bool isBusy;
    private string? statusMessage;
    private string? lastResetText;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var settings = await SystemSettingsService.GetSystemSettingsAsync();
            var lastReset = settings.FirstOrDefault(x => x.SettingID == (int)Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models.Enums.SystemSettings.LastResetDate);
            lastResetText = lastReset is null
                ? null
                : $"Last Reset Date Setting: {lastReset.SettingValue}";
        }
        catch
        {
            lastResetText = null;
        }
    }

    private async Task CreateOrdersAsync()
    {
        statusMessage = null;
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Create {model.OrderCount} internet test orders?");
        if (!confirmed)
        {
            return;
        }

        isBusy = true;

        try
        {
            await ModOrdersService.CreateRandomOrdersAsync(model.OrderCount);
            statusMessage = $"Created {model.OrderCount} internet orders.";
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

}
