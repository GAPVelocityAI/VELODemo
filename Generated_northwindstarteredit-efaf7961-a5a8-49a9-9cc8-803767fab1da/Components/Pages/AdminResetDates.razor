@page "/admin-reset-dates"
@rendermode InteractiveServer
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject IModOrdersService ModOrdersService
@inject IJSRuntime JS

<PageTitle>Admin Reset Dates</PageTitle>

<div class="container-fluid py-3 access-form access-admin-reset-dates">
    <h1 class="page-title mb-3">Admin - Reset Dates</h1>

    <div class="card">
        <div class="card-body">
            <p class="mb-3">Shift demo dates forward so data appears current.</p>

            <button type="button" class="btn btn-warning" tabindex="0" @onclick="ResetDatesAsync" disabled="@isBusy">Reset Dates</button>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="alert alert-info mt-3 mb-0" role="alert">@statusMessage</div>
            }
        </div>
    </div>
</div>

@code {
    private bool isBusy;
    private string? statusMessage;

    private async Task ResetDatesAsync()
    {
        statusMessage = null;

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Reset dates to current values?");
        if (!confirmed)
        {
            return;
        }

        isBusy = true;

        try
        {
            await ModOrdersService.SetDatesToCurrentAsync();
            statusMessage = "Done. Reopen forms or refresh pages to see updated dates.";
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }
}
