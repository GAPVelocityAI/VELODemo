@page "/credentials"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject IEmployeeService EmployeeService
@inject NavigationManager Navigation

<PageTitle>Credentials</PageTitle>

<div class="container-fluid py-3 access-form access-credentials">
    <h1 class="page-title mb-3">Create Credentials</h1>

    <div class="card mb-3">
        <div class="card-body">
            <EditForm Model="model" OnValidSubmit="AddMeAsync">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">First Name</label>
                        <InputText class="form-control" tabindex="0" @bind-Value="model.FirstName" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Last Name</label>
                        <InputText class="form-control" tabindex="1" @bind-Value="model.LastName" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Job Title</label>
                        <InputText class="form-control" tabindex="2" @bind-Value="model.JobTitle" />
                    </div>
                    @if (showWindowsUserName)
                    {
                        <div class="col-md-3">
                            <label class="form-label">Windows User Name</label>
                            <InputText class="form-control" tabindex="3" @bind-Value="model.WindowsUserName" readonly />
                        </div>
                    }
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary" tabindex="4" disabled="@isBusy">Add Me</button>
                    <button type="button" class="btn btn-outline-secondary" tabindex="5" @onclick="Exit">Exit</button>
                </div>
            </EditForm>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="alert alert-info mt-3 mb-0" role="alert">@statusMessage</div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header fw-semibold">Existing Login Rows</div>
        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="p-3 text-muted">Loading employees...</div>
            }
            else if (!existingLogins.Any())
            {
                <div class="p-3 text-muted">No employee logins found.</div>
            }
            else
            {
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Employee #</th>
                            <th>Name</th>
                            <th>Job Title</th>
                            <th>Windows User</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in existingLogins)
                        {
                            <tr>
                                <td>@row.EmployeeID</td>
                                <td>@(row.FullNameFNLN ?? $"{row.FirstName} {row.LastName}")</td>
                                <td>@row.JobTitle</td>
                                <td>@row.WindowsUserName</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    private readonly CredentialsModel model = new();
    private readonly bool showWindowsUserName = false;
    private List<EmployeeLoginDto> existingLogins = new();
    private bool isLoading = true;
    private bool isBusy;
    private string? statusMessage;

    protected override async Task OnInitializedAsync()
    {
        model.WindowsUserName = Environment.UserName;
        await LoadRowsAsync();
    }

    private async Task LoadRowsAsync()
    {
        isLoading = true;

        try
        {
            existingLogins = await EmployeeService.GetEmployeeLoginAsync();
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
            existingLogins = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AddMeAsync()
    {
        statusMessage = null;
        isBusy = true;

        try
        {
            var employee = new Employees
            {
                FirstName = model.FirstName,
                LastName = model.LastName,
                JobTitle = model.JobTitle,
                WindowsUserName = model.WindowsUserName,
                FullNameFNLN = $"{model.FirstName} {model.LastName}".Trim(),
                FullNameLNFN = $"{model.LastName}, {model.FirstName}".Trim(' ', ','),
            };

            var saved = await EmployeeService.CreateAsync(employee);
            statusMessage = "Employee created. Redirecting to Main Menu...";

            await LoadRowsAsync();

            Navigation.NavigateTo($"/main-menu?employeeId={saved.EmployeeID}");
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void Exit()
    {
        Navigation.NavigateTo("/login");
    }

    private sealed class CredentialsModel
    {
        [Required]
        public string FirstName { get; set; } = string.Empty;

        [Required]
        public string LastName { get; set; } = string.Empty;

        [Required]
        public string JobTitle { get; set; } = string.Empty;

        public string? WindowsUserName { get; set; }
    }
}
