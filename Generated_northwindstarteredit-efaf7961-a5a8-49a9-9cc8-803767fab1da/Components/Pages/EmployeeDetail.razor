@page "/employee-detail"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Components.Forms
@inject IEmployeeService EmployeeService

<PageTitle>Employee Detail</PageTitle>

<div class="container-fluid py-3 access-form access-employee-detail">
    <h1 class="page-title mb-3">Employee Detail</h1>

    <div class="card mb-3">
        <div class="card-body row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label" for="employee-selector">Employee</label>
                <select id="employee-selector" class="form-select" tabindex="0" value="@selectedEmployeeId" @onchange="OnEmployeeSelectionChanged">
                    <option value="0">-- Select Employee --</option>
                    @foreach (var row in employeeRows)
                    {
                        <option value="@row.EmployeeID">@(row.FullNameFNLN ?? $"{row.FirstName} {row.LastName}") (@row.EmployeeID)</option>
                    }
                </select>
            </div>
            <div class="col-md-6 d-flex gap-2">
                <button type="button" class="btn btn-outline-primary" tabindex="1" @onclick="StartNewEmployee">Add Employee</button>
                <button type="button" class="btn btn-outline-secondary" tabindex="2" @onclick="LoadEmployeesAsync" disabled="@isLoading">Refresh List</button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-info" role="alert">@statusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <div class="card mb-3">
        <div class="card-body">
            <EditForm Model="editModel" OnValidSubmit="SaveEmployeeAsync">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-md-2">
                        <label class="form-label">Employee ID</label>
                        <input class="form-control" value="@(editModel.EmployeeID == 0 ? "(new)" : editModel.EmployeeID)" readonly tabindex="-1" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">First Name</label>
                        <InputText class="form-control" tabindex="3" @bind-Value="editModel.FirstName" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Last Name</label>
                        <InputText class="form-control" tabindex="4" @bind-Value="editModel.LastName" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Job Title</label>
                        <InputText class="form-control" tabindex="5" @bind-Value="editModel.JobTitle" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Email</label>
                        <InputText class="form-control" tabindex="6" @bind-Value="editModel.EmailAddress" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Title</label>
                        <InputSelect TValue="string" class="form-select" tabindex="7" @bind-Value="editModel.Title">
                            <option value="">--</option>
                            <option value="Mr.">Mr.</option>
                            <option value="Ms.">Ms.</option>
                            <option value="Dr.">Dr.</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Primary Phone</label>
                        <InputText class="form-control" tabindex="8" @bind-Value="editModel.PrimaryPhone" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Secondary Phone</label>
                        <InputText class="form-control" tabindex="9" @bind-Value="editModel.SecondaryPhone" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Windows User Name</label>
                        <InputText class="form-control" tabindex="10" @bind-Value="editModel.WindowsUserName" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Notes</label>
                        <InputTextArea class="form-control" tabindex="11" @bind-Value="editModel.Notes" />
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary" tabindex="12" disabled="@isSaving">Save</button>
                </div>
            </EditForm>
        </div>
    </div>

    @if (editModel.EmployeeID > 0)
    {
        <EmployeeDetailOrderList EmployeeID="@editModel.EmployeeID" />
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "employeeId")]
    public int? EmployeeId { get; set; }

    private List<EmployeeListDto> employeeRows = new();
    private Employees editModel = CreateEmptyEmployee();
    private int selectedEmployeeId;
    private bool isLoading = true;
    private bool isSaving;
    private string? statusMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployeesAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (EmployeeId.HasValue && EmployeeId.Value > 0 && EmployeeId.Value != selectedEmployeeId)
        {
            selectedEmployeeId = EmployeeId.Value;
            await LoadSelectedEmployeeAsync(selectedEmployeeId);
        }
    }

    private async Task LoadEmployeesAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            employeeRows = await EmployeeService.GetEmployeeListAsync();

            if (selectedEmployeeId <= 0)
            {
                selectedEmployeeId = EmployeeId.GetValueOrDefault() > 0
                    ? EmployeeId!.Value
                    : employeeRows.FirstOrDefault()?.EmployeeID ?? 0;
            }

            if (selectedEmployeeId > 0)
            {
                await LoadSelectedEmployeeAsync(selectedEmployeeId);
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            employeeRows = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadSelectedEmployeeAsync(int employeeId)
    {
        try
        {
            var employee = await EmployeeService.GetByIdAsync(employeeId);
            if (employee is not null)
            {
                editModel = employee;
                statusMessage = null;
                errorMessage = null;
            }
            else
            {
                statusMessage = $"Employee {employeeId} was not found.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void StartNewEmployee()
    {
        selectedEmployeeId = 0;
        editModel = CreateEmptyEmployee();
        statusMessage = "Creating a new employee.";
        errorMessage = null;
    }

    private async Task SaveEmployeeAsync()
    {
        isSaving = true;
        errorMessage = null;
        statusMessage = null;

        try
        {
            editModel.FullNameFNLN = BuildFullNameFNLN(editModel.FirstName, editModel.LastName);
            editModel.FullNameLNFN = BuildFullNameLNFN(editModel.FirstName, editModel.LastName);

            Employees saved;
            if (editModel.EmployeeID <= 0)
            {
                saved = await EmployeeService.CreateAsync(editModel);
                statusMessage = "Employee created.";
            }
            else
            {
                saved = await EmployeeService.UpdateAsync(editModel);
                statusMessage = "Employee updated.";
            }

            selectedEmployeeId = saved.EmployeeID;
            await LoadEmployeesAsync();
            await LoadSelectedEmployeeAsync(selectedEmployeeId);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task OnEmployeeSelectionChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(Convert.ToString(args.Value), out var employeeId))
        {
            return;
        }

        if (employeeId <= 0)
        {
            StartNewEmployee();
            return;
        }

        selectedEmployeeId = employeeId;
        await LoadSelectedEmployeeAsync(employeeId);
    }

    private static Employees CreateEmptyEmployee()
    {
        return new Employees
        {
            FirstName = string.Empty,
            LastName = string.Empty,
            JobTitle = string.Empty,
        };
    }

    private static string BuildFullNameFNLN(string firstName, string lastName) => $"{firstName} {lastName}".Trim();

    private static string BuildFullNameLNFN(string firstName, string lastName) => $"{lastName}, {firstName}".Trim(' ', ',');
}
