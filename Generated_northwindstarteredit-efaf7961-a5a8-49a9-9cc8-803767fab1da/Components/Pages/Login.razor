@page "/login"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject IEmployeeService EmployeeService
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<div class="container-fluid py-3 access-form access-login">
    <h1 class="page-title mb-3">Login</h1>

    <div class="card">
        <div class="card-body">
            <EditForm Model="model" OnValidSubmit="LoginAsync">
                <DataAnnotationsValidator />

                <div class="row g-3 align-items-end">
                    <div class="col-md-6">
                        <label class="form-label" for="employee-login">Select Employee</label>
                        <InputSelect id="employee-login" TValue="int" class="form-select" tabindex="0" @bind-Value="model.EmployeeID">
                            <option value="0">-- Select Login --</option>
                            @foreach (var employee in employees)
                            {
                                <option value="@employee.EmployeeID">@employee.FullNameFNLN</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-6 d-flex gap-2">
                        <button type="submit" class="btn btn-primary" tabindex="1" disabled="@isBusy">Login</button>
                        <button type="button" class="btn btn-outline-secondary" tabindex="2" @onclick="OpenCredentials">Create Credentials</button>
                    </div>
                </div>
            </EditForm>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="alert alert-info mt-3 mb-0" role="alert">@statusMessage</div>
            }
        </div>
    </div>
</div>

@code {
    private List<CboEmployeeDto> employees = new();
    private LoginModel model = new();
    private bool isBusy;
    private string? statusMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            employees = await EmployeeService.GetCboEmployeesAsync();
            model.EmployeeID = employees.FirstOrDefault()?.EmployeeID ?? 0;
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
    }

    private async Task LoginAsync()
    {
        isBusy = true;

        try
        {
            var selected = employees.FirstOrDefault(x => x.EmployeeID == model.EmployeeID);
            if (selected is null)
            {
                statusMessage = "Please select a valid login.";
                return;
            }

            statusMessage = $"Logged in as {selected.FullNameFNLN}.";
            Navigation.NavigateTo($"/main-menu?employeeId={selected.EmployeeID}");
            await Task.CompletedTask;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void OpenCredentials()
    {
        Navigation.NavigateTo("/credentials");
    }

    private sealed class LoginModel
    {
        [Range(1, int.MaxValue, ErrorMessage = "Please select an employee.")]
        public int EmployeeID { get; set; }
    }
}
