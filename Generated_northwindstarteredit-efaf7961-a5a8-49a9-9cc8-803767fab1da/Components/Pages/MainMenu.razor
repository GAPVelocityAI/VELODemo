@page "/main-menu"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Components.Forms
@inject NavigationManager Navigation

<PageTitle>Main Menu</PageTitle>

<div class="container-fluid py-3 access-form access-main-menu">
    <h1 class="page-title mb-3">Main Menu</h1>

    <div class="card mb-3">
        <div class="card-body d-flex flex-wrap gap-2">
            <button type="button" class="btn @(selectedPanel == MainMenuPanel.Orders ? "btn-primary" : "btn-outline-primary")" tabindex="0" @onclick="() => SelectPanel(MainMenuPanel.Orders)">Orders</button>
            <button type="button" class="btn btn-outline-primary" tabindex="1" @onclick="AddOrder">Add Order</button>
            <button type="button" class="btn btn-outline-primary" tabindex="2" @onclick="OpenCustomers">Customers</button>
            <button type="button" class="btn btn-outline-primary" tabindex="3" @onclick="OpenEmployees">Employees</button>
            <button type="button" class="btn @(selectedPanel == MainMenuPanel.Products ? "btn-primary" : "btn-outline-primary")" tabindex="4" @onclick="() => SelectPanel(MainMenuPanel.Products)">Products</button>
            <button type="button" class="btn @(selectedPanel == MainMenuPanel.Reports ? "btn-primary" : "btn-outline-primary")" tabindex="5" @onclick="() => SelectPanel(MainMenuPanel.Reports)">Reports</button>
            <button type="button" class="btn @(selectedPanel == MainMenuPanel.Learn ? "btn-primary" : "btn-outline-primary")" tabindex="6" @onclick="() => SelectPanel(MainMenuPanel.Learn)">Learn</button>
            <button type="button" class="btn btn-outline-secondary" tabindex="7" @onclick="OpenNorthwindFeatures">Northwind Features</button>
            <button type="button" class="btn btn-outline-secondary" tabindex="8" @onclick="OpenAdmin">Admin</button>
            <button type="button" class="btn btn-outline-danger" tabindex="9" @onclick="Logout">Exit</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-info" role="alert">@statusMessage</div>
    }

    @if (selectedPanel == MainMenuPanel.Orders)
    {
        <MainMenuOrderList CurrentEmployeeId="@CurrentEmployeeId" />
    }
    else if (selectedPanel == MainMenuPanel.Products)
    {
        <MainMenuProductList />
    }
    else if (selectedPanel == MainMenuPanel.Reports)
    {
        <MainMenuReports />
    }
    else
    {
        <MainMenuLearn />
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "employeeId")]
    public int? EmployeeId { get; set; }

    private MainMenuPanel selectedPanel = MainMenuPanel.Orders;
    private string? statusMessage;

    private int CurrentEmployeeId => EmployeeId.GetValueOrDefault();

    private void SelectPanel(MainMenuPanel panel)
    {
        selectedPanel = panel;
        statusMessage = panel == MainMenuPanel.Orders && CurrentEmployeeId <= 0
            ? "No employee id was provided. 'My Orders' in the order panel will fall back to all orders."
            : null;
    }

    private void AddOrder()
    {
        Navigation.NavigateTo("/order-details");
    }

    private void OpenCustomers()
    {
        Navigation.NavigateTo("/customer-list");
    }

    private void OpenEmployees()
    {
        Navigation.NavigateTo("/employee-detail");
    }

    private void OpenAdmin()
    {
        Navigation.NavigateTo("/admin");
    }

    private void OpenNorthwindFeatures()
    {
        Navigation.NavigateTo("/northwind-features");
    }

    private void Logout()
    {
        Navigation.NavigateTo("/login");
    }

    private enum MainMenuPanel
    {
        Orders,
        Products,
        Reports,
        Learn,
    }
}
