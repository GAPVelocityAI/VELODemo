@page "/main-menu-learn"
@rendermode InteractiveServer
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject NavigationManager Navigation

<PageTitle>Main Menu Learn</PageTitle>

<div class="container-fluid py-3 access-form access-main-menu-learn">
    <h1 class="page-title mb-3">Learn</h1>

    <div class="card">
        <div class="card-body d-grid gap-2">
            <button type="button" class="btn btn-outline-primary" tabindex="0" @onclick="OpenTechCommunity">Access Tech Community</button>
            <button type="button" class="btn btn-outline-primary" tabindex="1" @onclick="OpenLearnMore">Learn More About Access</button>
            <button type="button" class="btn btn-outline-primary" tabindex="2" @onclick="OpenForum">Access Forum</button>
        </div>
    </div>
</div>

@code {
    private void OpenTechCommunity() => Navigation.NavigateTo("https://techcommunity.microsoft.com/t5/access/bd-p/Access", forceLoad: true);

    private void OpenLearnMore() => Navigation.NavigateTo("https://support.microsoft.com/access", forceLoad: true);

    private void OpenForum() => Navigation.NavigateTo("https://answers.microsoft.com", forceLoad: true);
}
