@page "/main-menu-reports"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject IReportService ReportService

<PageTitle>Main Menu Reports</PageTitle>

<div class="container-fluid py-3 access-form access-main-menu-reports">
    <h1 class="page-title mb-3">Reports</h1>

    <div class="card mb-3">
        <div class="card-body">
            <EditForm Model="filter" OnValidSubmit="PreviewAsync">
                <DataAnnotationsValidator />

                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label">Start Date</label>
                        <InputDate TValue="DateTime" class="form-control" tabindex="0" @bind-Value="filter.StartDate" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">End Date</label>
                        <InputDate TValue="DateTime" class="form-control" tabindex="1" @bind-Value="filter.EndDate" />
                    </div>
                    <div class="col-md-6 d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-outline-primary" tabindex="2" @onclick="RunSalesByEmployeeAsync" disabled="@isLoading">Monthly Orders per Employee</button>
                        <button type="button" class="btn btn-outline-primary" tabindex="3" @onclick="RunSalesByProductMonthlyAsync" disabled="@isLoading">Monthly Orders per Product</button>
                        <button type="button" class="btn btn-outline-primary" tabindex="4" @onclick="RunSalesByProductQuarterlyAsync" disabled="@isLoading">Quarterly Orders per Product</button>
                        <button type="button" class="btn btn-outline-secondary" tabindex="5" @onclick="RunEmployeeEmailListAsync" disabled="@isLoading">Employee Email List</button>
                        <button type="button" class="btn btn-outline-secondary" tabindex="6" @onclick="RunEmployeePhoneListAsync" disabled="@isLoading">Employee Phone List</button>
                        <button type="submit" class="btn btn-primary" tabindex="7" disabled="@isLoading">Preview</button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <div class="card">
        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="p-3 text-muted">Loading report data...</div>
            }
            else if (activeView == ReportView.None)
            {
                <div class="p-3 text-muted">Select a report action.</div>
            }
            else if (activeView == ReportView.SalesByEmployee)
            {
                @RenderSalesByEmployeeTable()
            }
            else if (activeView == ReportView.SalesByProductMonthly)
            {
                @RenderSalesByProductMonthlyTable()
            }
            else if (activeView == ReportView.SalesByProductQuarterly)
            {
                @RenderSalesByProductQuarterlyTable()
            }
            else if (activeView == ReportView.EmployeeEmail)
            {
                @RenderEmailTable()
            }
            else
            {
                @RenderPhoneTable()
            }
        </div>
    </div>
</div>

@code {
    private readonly ReportFilterModel filter = new()
    {
        StartDate = DateTime.Today.AddMonths(-1),
        EndDate = DateTime.Today,
    };

    private List<SalesByEmployeeReportDto> salesByEmployee = new();
    private List<SalesByProductReportDto> salesByProduct = new();
    private List<EmployeeEmailListDto> employeeEmails = new();
    private List<EmployeePhoneListDto> employeePhones = new();
    private ReportView activeView;
    private bool isLoading;
    private string? errorMessage;

    private async Task PreviewAsync()
    {
        switch (activeView)
        {
            case ReportView.SalesByEmployee:
                await RunSalesByEmployeeAsync();
                break;
            case ReportView.SalesByProductMonthly:
                await RunSalesByProductMonthlyAsync();
                break;
            case ReportView.SalesByProductQuarterly:
                await RunSalesByProductQuarterlyAsync();
                break;
            case ReportView.EmployeeEmail:
                await RunEmployeeEmailListAsync();
                break;
            case ReportView.EmployeePhone:
                await RunEmployeePhoneListAsync();
                break;
            default:
                await RunSalesByEmployeeAsync();
                break;
        }
    }

    private async Task RunSalesByEmployeeAsync()
    {
        activeView = ReportView.SalesByEmployee;
        await ExecuteAsync(async () =>
        {
            salesByEmployee = await ReportService.GetReportSalesByEmployeeAsync(filter.StartDate, filter.EndDate);
        });
    }

    private async Task RunSalesByProductMonthlyAsync()
    {
        activeView = ReportView.SalesByProductMonthly;
        await ExecuteAsync(async () =>
        {
            salesByProduct = await ReportService.GetReportSalesByProductAsync(filter.StartDate, filter.EndDate);
        });
    }

    private async Task RunSalesByProductQuarterlyAsync()
    {
        activeView = ReportView.SalesByProductQuarterly;
        await ExecuteAsync(async () =>
        {
            salesByProduct = await ReportService.GetReportSalesByProductAsync(filter.StartDate, filter.EndDate);
        });
    }

    private async Task RunEmployeeEmailListAsync()
    {
        activeView = ReportView.EmployeeEmail;
        await ExecuteAsync(async () =>
        {
            employeeEmails = await ReportService.GetEmployeeEmailListAsync();
        });
    }

    private async Task RunEmployeePhoneListAsync()
    {
        activeView = ReportView.EmployeePhone;
        await ExecuteAsync(async () =>
        {
            employeePhones = await ReportService.GetEmployeePhoneListAsync();
        });
    }

    private async Task ExecuteAsync(Func<Task> action)
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            if (filter.EndDate < filter.StartDate)
            {
                errorMessage = "End Date must be on or after Start Date.";
                return;
            }

            await action();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private RenderFragment RenderSalesByEmployeeTable() => __builder =>
    {
        if (!salesByEmployee.Any())
        {
            __builder.AddMarkupContent(0, "<div class=\"p-3 text-muted\">No rows found.</div>");
            return;
        }

        __builder.AddMarkupContent(1, "<table class=\"table table-sm table-hover mb-0\"><thead><tr><th>Employee</th><th>Month</th><th class=\"text-end\">Order Total</th></tr></thead><tbody>");
        var seq = 2;
        foreach (var row in salesByEmployee.OrderBy(x => x.MonthYearSort).ThenBy(x => x.FullNameFNLN))
        {
            __builder.AddMarkupContent(seq++, $"<tr><td>{row.FullNameFNLN}</td><td>{row.MonthYear}</td><td class=\"text-end\">{row.OrderTotal:C}</td></tr>");
        }
        __builder.AddMarkupContent(seq, "</tbody></table>");
    };

    private RenderFragment RenderSalesByProductMonthlyTable() => __builder =>
    {
        if (!salesByProduct.Any())
        {
            __builder.AddMarkupContent(0, "<div class=\"p-3 text-muted\">No rows found.</div>");
            return;
        }

        __builder.AddMarkupContent(1, "<table class=\"table table-sm table-hover mb-0\"><thead><tr><th>Product</th><th>Month</th><th class=\"text-end\">Order Total</th></tr></thead><tbody>");
        var seq = 2;
        foreach (var row in salesByProduct.OrderBy(x => x.MonthYearSort).ThenBy(x => x.ProductName))
        {
            __builder.AddMarkupContent(seq++, $"<tr><td>{row.ProductName}</td><td>{row.MonthYear}</td><td class=\"text-end\">{row.OrderTotal:C}</td></tr>");
        }
        __builder.AddMarkupContent(seq, "</tbody></table>");
    };

    private RenderFragment RenderSalesByProductQuarterlyTable() => __builder =>
    {
        if (!salesByProduct.Any())
        {
            __builder.AddMarkupContent(0, "<div class=\"p-3 text-muted\">No rows found.</div>");
            return;
        }

        var grouped = salesByProduct
            .GroupBy(x => new { x.ProductID, x.ProductName, x.QuarterYear })
            .Select(g => new
            {
                g.Key.ProductID,
                g.Key.ProductName,
                g.Key.QuarterYear,
                OrderTotal = g.Sum(x => x.OrderTotal),
            })
            .OrderBy(x => x.QuarterYear)
            .ThenBy(x => x.ProductName)
            .ToList();

        __builder.AddMarkupContent(1, "<table class=\"table table-sm table-hover mb-0\"><thead><tr><th>Product</th><th>Quarter</th><th class=\"text-end\">Order Total</th></tr></thead><tbody>");
        var seq = 2;
        foreach (var row in grouped)
        {
            __builder.AddMarkupContent(seq++, $"<tr><td>{row.ProductName}</td><td>{row.QuarterYear}</td><td class=\"text-end\">{row.OrderTotal:C}</td></tr>");
        }
        __builder.AddMarkupContent(seq, "</tbody></table>");
    };

    private RenderFragment RenderEmailTable() => __builder =>
    {
        if (!employeeEmails.Any())
        {
            __builder.AddMarkupContent(0, "<div class=\"p-3 text-muted\">No rows found.</div>");
            return;
        }

        __builder.AddMarkupContent(1, "<table class=\"table table-sm table-hover mb-0\"><thead><tr><th>Employee</th><th>Email</th></tr></thead><tbody>");
        var seq = 2;
        foreach (var row in employeeEmails.OrderBy(x => x.FullNameFNLN))
        {
            __builder.AddMarkupContent(seq++, $"<tr><td>{row.FullNameFNLN}</td><td>{row.EmailAddress}</td></tr>");
        }
        __builder.AddMarkupContent(seq, "</tbody></table>");
    };

    private RenderFragment RenderPhoneTable() => __builder =>
    {
        if (!employeePhones.Any())
        {
            __builder.AddMarkupContent(0, "<div class=\"p-3 text-muted\">No rows found.</div>");
            return;
        }

        __builder.AddMarkupContent(1, "<table class=\"table table-sm table-hover mb-0\"><thead><tr><th>Employee</th><th>Primary Phone</th><th>Secondary Phone</th></tr></thead><tbody>");
        var seq = 2;
        foreach (var row in employeePhones.OrderBy(x => x.FullNameFNLN))
        {
            __builder.AddMarkupContent(seq++, $"<tr><td>{row.FullNameFNLN}</td><td>{row.PrimaryPhone}</td><td>{row.SecondaryPhone}</td></tr>");
        }
        __builder.AddMarkupContent(seq, "</tbody></table>");
    };

    private sealed class ReportFilterModel
    {
        [Required]
        public DateTime StartDate { get; set; }

        [Required]
        public DateTime EndDate { get; set; }
    }

    private enum ReportView
    {
        None,
        SalesByEmployee,
        SalesByProductMonthly,
        SalesByProductQuarterly,
        EmployeeEmail,
        EmployeePhone,
    }
}
