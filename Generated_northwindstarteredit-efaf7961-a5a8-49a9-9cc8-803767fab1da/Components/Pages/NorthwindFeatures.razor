@page "/northwind-features"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject NorthwindstartereditEfaf7961A5A849A99Cc8803767Fab1DaDbContext Db

<PageTitle>Northwind Features</PageTitle>

<div class="container-fluid py-3 access-form access-northwind-features">
    <h1 class="page-title mb-3">Northwind Features</h1>

    <div class="card">
        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="p-3 text-muted">Loading features...</div>
            }
            else if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger m-3" role="alert">@errorMessage</div>
            }
            else if (!featureRows.Any())
            {
                <div class="p-3 text-muted">No feature rows found.</div>
            }
            else
            {
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Description</th>
                            <th>Navigation</th>
                            <th>Learn More</th>
                            <th>Help Keywords</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in featureRows)
                        {
                            <tr>
                                <td>@row.ItemName</td>
                                <td>@row.Description</td>
                                <td>@row.Navigation</td>
                                <td>@row.LearnMore</td>
                                <td>@row.HelpKeywords</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    @* TODO: No dedicated service method exists for record source "NorthwindFeatures"; create INorthwindFeaturesService for parity. *@
</div>

@code {
    private List<Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models.NorthwindFeatures> featureRows = new();
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            featureRows = await Db.NorthwindFeatures
                .OrderBy(x => x.NorthwindFeaturesID)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            featureRows = new();
        }
        finally
        {
            isLoading = false;
        }
    }
}
