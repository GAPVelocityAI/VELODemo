@page "/order-details"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Components.Forms
@using OrderStatusEnum = Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models.Enums.OrderStatus
@inject IOrderService OrderService
@inject ILookupService LookupService
@inject IEmployeeService EmployeeService
@inject IReportService ReportService
@inject IJSRuntime JS

<PageTitle>Order Details</PageTitle>

<div class="container-fluid py-3 access-form access-order-details">
    <h1 class="page-title mb-3">Order Details</h1>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-info" role="alert">@statusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <div class="row g-3 mb-3">
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Orders</span>
                    <button type="button" class="btn btn-sm btn-outline-secondary" tabindex="0" @onclick="LoadOrdersAsync" disabled="@isLoading">Refresh</button>
                </div>
                <div class="card-body p-0">
                    @if (isLoading)
                    {
                        <div class="p-3 text-muted">Loading orders...</div>
                    }
                    else if (!orderRows.Any())
                    {
                        <div class="p-3 text-muted">No orders found.</div>
                    }
                    else
                    {
                        <table class="table table-sm table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Order #</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in orderRows)
                                {
                                    <tr class="@(row.OrderID == editModel.OrderID ? "table-primary" : string.Empty)">
                                        <td>@row.OrderID</td>
                                        <td>@row.OrderDate.ToString("d")</td>
                                        <td>@row.StatusName</td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-primary" tabindex="1" @onclick="() => SelectOrderAsync(row.OrderID)">Open</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Order Header</span>
                    <button type="button" class="btn btn-sm btn-outline-primary" tabindex="2" @onclick="StartNewOrder">Add Order</button>
                </div>
                <div class="card-body">
                    <EditForm Model="editModel" OnValidSubmit="SaveOrderAsync">
                        <DataAnnotationsValidator />

                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">Order ID</label>
                                <input class="form-control" value="@(editModel.OrderID == 0 ? "(new)" : editModel.OrderID)" readonly tabindex="-1" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Order Date</label>
                                <InputDate TValue="DateTime" class="form-control" tabindex="3" readonly @bind-Value="editModel.OrderDate" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Shipped Date</label>
                                <InputDate TValue="DateTime?" class="form-control" tabindex="4" readonly @bind-Value="editModel.ShippedDate" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Paid Date</label>
                                <InputDate TValue="DateTime?" class="form-control" tabindex="5" readonly @bind-Value="editModel.PaidDate" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Employee</label>
                                <InputSelect TValue="int" class="form-select" tabindex="6" @bind-Value="editModel.EmployeeID">
                                    <option value="0">-- select employee --</option>
                                    @foreach (var employee in employees)
                                    {
                                        <option value="@employee.EmployeeID">@employee.FullNameFNLN</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Customer</label>
                                <InputSelect TValue="int" class="form-select" tabindex="7" @bind-Value="editModel.CustomerID">
                                    <option value="0">-- select customer --</option>
                                    @foreach (var customer in customers)
                                    {
                                        <option value="@customer.CustomerID">@customer.CustomerName</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Status</label>
                                <InputSelect TValue="int" class="form-select" tabindex="-1" disabled @bind-Value="editModel.StatusID">
                                    <option value="0">-- select status --</option>
                                    @foreach (var status in statuses)
                                    {
                                        <option value="@status.StatusID">@status.StatusName</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Notes</label>
                                <InputTextArea class="form-control" tabindex="8" @bind-Value="editModel.Notes" />
                            </div>
                        </div>

                        <div class="mt-3 d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-primary" tabindex="9" disabled="@isSaving">Save</button>
                            <button type="button" class="btn btn-danger" tabindex="10" @onclick="DeleteOrderAsync" disabled="@(isSaving || editModel.OrderID <= 0)">Delete Order</button>
                            <button type="button" class="btn btn-outline-primary" tabindex="11" @onclick="CreateInvoiceAsync" disabled="@(isSaving || editModel.OrderID <= 0)">Create Invoice</button>
                            <button type="button" class="btn btn-outline-primary" tabindex="12" @onclick="ShipOrderAsync" disabled="@(isSaving || editModel.OrderID <= 0)">Ship Order</button>
                            <button type="button" class="btn btn-outline-primary" tabindex="13" @onclick="ReceivePaymentAsync" disabled="@(isSaving || editModel.OrderID <= 0)">Receive Payment</button>
                            <button type="button" class="btn btn-outline-primary" tabindex="14" @onclick="CloseOrderAsync" disabled="@(isSaving || editModel.OrderID <= 0)">Close Order</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>

    @if (invoiceRows.Any())
    {
        <div class="card mb-3">
            <div class="card-header fw-semibold">Invoice Preview Rows (Order @editModel.OrderID)</div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Line Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in invoiceRows)
                        {
                            <tr>
                                <td>@row.ProductName</td>
                                <td class="text-end">@row.Quantity</td>
                                <td class="text-end">@row.UnitPrice.ToString("C")</td>
                                <td class="text-end">@((row.Quantity * row.UnitPrice).ToString("C"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (editModel.OrderID > 0)
    {
        <OrderDetailsItems OrderID="@editModel.OrderID" />
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "orderId")]
    public int? OrderId { get; set; }

    private List<OrderWithStatusDto> orderRows = new();
    private List<CboCustomerDto> customers = new();
    private List<CboEmployeeDto> employees = new();
    private List<CboOrderStatusDto> statuses = new();
    private List<InvoiceDto> invoiceRows = new();
    private Orders editModel = CreateDefaultOrder();
    private int selectedOrderId;
    private bool isLoading = true;
    private bool isSaving;
    private string? statusMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupsAsync();
        await LoadOrdersAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (OrderId.HasValue && OrderId.Value > 0 && OrderId.Value != selectedOrderId)
        {
            selectedOrderId = OrderId.Value;
            await SelectOrderAsync(selectedOrderId);
        }
    }

    private async Task LoadLookupsAsync()
    {
        customers = await LookupService.GetCboCustomersAsync();
        employees = await EmployeeService.GetCboEmployeesAsync();
        statuses = await LookupService.GetCboOrderStatusAsync();
    }

    private async Task LoadOrdersAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            orderRows = await OrderService.GetOrderAsync();

            if (selectedOrderId <= 0)
            {
                selectedOrderId = OrderId.GetValueOrDefault() > 0
                    ? OrderId!.Value
                    : orderRows.FirstOrDefault()?.OrderID ?? 0;
            }

            if (selectedOrderId > 0)
            {
                await SelectOrderAsync(selectedOrderId);
            }
            else
            {
                StartNewOrder();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            orderRows = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SelectOrderAsync(int orderId)
    {
        try
        {
            var order = await OrderService.GetByIdAsync(orderId);
            if (order is null)
            {
                statusMessage = $"Order {orderId} was not found.";
                return;
            }

            selectedOrderId = orderId;
            editModel = order;
            invoiceRows = new();
            statusMessage = null;
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void StartNewOrder()
    {
        selectedOrderId = 0;
        invoiceRows = new();

        editModel = new Orders
        {
            OrderDate = DateTime.Today,
            EmployeeID = employees.FirstOrDefault()?.EmployeeID ?? 0,
            CustomerID = customers.FirstOrDefault()?.CustomerID ?? 0,
            StatusID = (int)OrderStatusEnum.New,
        };

        statusMessage = "Creating a new order.";
    }

    private async Task SaveOrderAsync()
    {
        isSaving = true;
        errorMessage = null;
        statusMessage = null;

        try
        {
            Orders saved;
            if (editModel.OrderID <= 0)
            {
                saved = await OrderService.CreateAsync(editModel);
                statusMessage = "Order created.";
            }
            else
            {
                saved = await OrderService.UpdateAsync(editModel);
                statusMessage = "Order updated.";
            }

            selectedOrderId = saved.OrderID;
            await LoadOrdersAsync();
            await SelectOrderAsync(selectedOrderId);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteOrderAsync()
    {
        if (editModel.OrderID <= 0)
        {
            return;
        }

        if (!CanDelete(editModel.StatusID))
        {
            statusMessage = "An order can only be deleted when status is New or Invoiced.";
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to permanently delete this order?");
        if (!confirmed)
        {
            return;
        }

        isSaving = true;

        try
        {
            await OrderService.DeleteAsync(editModel.OrderID);
            statusMessage = "Order deleted.";
            StartNewOrder();
            await LoadOrdersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task CreateInvoiceAsync()
    {
        if (editModel.OrderID <= 0)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Create invoice preview for this order?");
        if (!confirmed)
        {
            return;
        }

        isSaving = true;

        try
        {
            var allInvoiceRows = await ReportService.GetInvoiceAsync();
            invoiceRows = allInvoiceRows.Where(x => x.OrderID == editModel.OrderID).ToList();
            statusMessage = invoiceRows.Any()
                ? $"Loaded {invoiceRows.Count} invoice lines."
                : "No invoice lines were found for this order.";

            // TODO: Add IReportService.GetInvoiceByOrderIdAsync(int orderId) for server-side filtering.
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            invoiceRows = new();
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ShipOrderAsync()
    {
        await ApplyWorkflowAsync(
            "Was the order shipped today?",
            order =>
            {
                order.ShippedDate = DateTime.Today;
                order.StatusID = (int)OrderStatusEnum.Shipped;
            },
            "Order marked as shipped.");
    }

    private async Task ReceivePaymentAsync()
    {
        await ApplyWorkflowAsync(
            "Was the order paid today?",
            order =>
            {
                order.PaidDate = DateTime.Today;
                order.StatusID = (int)OrderStatusEnum.Paid;
            },
            "Order marked as paid.");
    }

    private async Task CloseOrderAsync()
    {
        await ApplyWorkflowAsync(
            "Close this order now?",
            order =>
            {
                order.StatusID = (int)OrderStatusEnum.Closed;
                order.ModifiedOn = DateTime.Now;
            },
            "Order marked as closed.");
    }

    private async Task ApplyWorkflowAsync(string confirmMessage, Action<Orders> updateAction, string successMessage)
    {
        if (editModel.OrderID <= 0)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", confirmMessage);
        if (!confirmed)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;

        try
        {
            updateAction(editModel);
            await OrderService.UpdateAsync(editModel);
            statusMessage = successMessage;
            await LoadOrdersAsync();
            await SelectOrderAsync(editModel.OrderID);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private static bool CanDelete(int statusId)
    {
        return statusId == (int)OrderStatusEnum.New || statusId == (int)OrderStatusEnum.Invoiced;
    }

    private static Orders CreateDefaultOrder()
    {
        return new Orders
        {
            OrderDate = DateTime.Today,
            StatusID = (int)OrderStatusEnum.New,
        };
    }
}
