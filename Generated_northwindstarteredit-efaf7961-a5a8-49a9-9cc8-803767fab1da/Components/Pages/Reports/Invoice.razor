@page "/reports/invoice"
@rendermode InteractiveServer
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject IReportService ReportService
@inject IJSRuntime JSRuntime

<PageTitle>Invoice Report</PageTitle>

<div class="container-fluid access-report access-invoice">
    <div class="row mb-4 report-header-section">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="page-title">
                    <i class="bi bi-bar-chart-line-fill me-2 text-primary"></i>
                    Invoice Report
                </h1>
                <p class="page-subtitle">Record Source: qryInvoice</p>
            </div>
            <button class="btn btn-outline-secondary" tabindex="0" @onclick="PrintReport">
                <i class="bi bi-printer me-1"></i>Print
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-4">
            <div class="spinner-border text-primary"></div>
            <p class="text-muted mt-2">Loading report data...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
        </div>
    }
    else if (!groupedInvoices.Any())
    {
        <div class="text-center py-4">
            <i class="bi bi-clipboard-x fs-1 text-muted"></i>
            <p class="text-muted">No data available for this report</p>
        </div>
    }
    else
    {
        <div class="card report-detail-section">
            <div class="card-body p-0">
                <table class="table table-hover mb-0 report-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Code</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Line Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var orderGroup in groupedInvoices)
                        {
                            var first = orderGroup.First();
                            <tr class="table-light">
                                <td colspan="5" class="fw-semibold">
                                    <i class="bi bi-folder2-open me-1"></i>
                                    Order #@orderGroup.Key — @first.CustomerName (@(first.OrderDate.ToString("d")))
                                </td>
                            </tr>

                            @foreach (var item in orderGroup)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td>@item.ProductCode</td>
                                    <td class="text-end">@item.Quantity</td>
                                    <td class="text-end">@item.UnitPrice.ToString("C")</td>
                                    <td class="text-end">@GetLineTotal(item).ToString("C")</td>
                                </tr>
                            }

                            <tr class="table-light">
                                <td colspan="4" class="text-end fst-italic">Subtotal (Order #@orderGroup.Key)</td>
                                <td class="text-end fw-semibold">@orderGroup.Sum(x => x.Quantity * x.UnitPrice).ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-light fw-bold">
                            <td colspan="4" class="text-end">Grand Total</td>
                            <td class="text-end">@grandTotal.ToString("C")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="mt-2 text-muted small report-footer-section">Generated: @generatedOn.ToString("g")</div>
    }
</div>

@code {
    private List<InvoiceDto> invoiceData = new();
    private List<IGrouping<int, InvoiceDto>> groupedInvoices = new();
    private decimal grandTotal;
    private bool isLoading = true;
    private string? errorMessage;
    private DateTime generatedOn = DateTime.Now;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            invoiceData = await ReportService.GetInvoiceAsync();
            invoiceData = invoiceData
                .OrderBy(x => x.OrderID)
                .ThenBy(x => x.ProductName)
                .ToList();

            groupedInvoices = invoiceData
                .GroupBy(x => x.OrderID)
                .OrderBy(g => g.Key)
                .ToList();

            grandTotal = invoiceData.Sum(x => x.Quantity * x.UnitPrice);
            generatedOn = DateTime.Now;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static decimal GetLineTotal(InvoiceDto item) => item.Quantity * item.UnitPrice;

    private async Task PrintReport()
    {
        await JSRuntime.InvokeVoidAsync("window.print");
    }
}
