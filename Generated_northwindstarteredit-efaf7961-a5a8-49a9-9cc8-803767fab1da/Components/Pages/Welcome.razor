@page "/welcome"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.EntityFrameworkCore
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models
@using Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Services
@inject NorthwindstartereditEfaf7961A5A849A99Cc8803767Fab1DaDbContext Db
@inject ISystemSettingsService SystemSettingsService
@inject NavigationManager Navigation

<PageTitle>Welcome</PageTitle>

<div class="container-fluid py-3 access-form access-welcome">
    <h1 class="page-title mb-3">Welcome</h1>

    <div class="card mb-3">
        <div class="card-body">
            @if (isLoading)
            {
                <p class="text-muted mb-0">Loading welcome content...</p>
            }
            else if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger mb-0" role="alert">@errorMessage</div>
            }
            else
            {
                <p class="mb-2">@welcomeText</p>
                @if (!string.IsNullOrWhiteSpace(learnText))
                {
                    <p class="mb-0 text-muted">@learnText</p>
                }
            }
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <EditForm Model="model" OnValidSubmit="ContinueAsync">
                <DataAnnotationsValidator />

                <div class="form-check mb-3">
                    <InputCheckbox id="show-welcome" class="form-check-input" tabindex="0" @bind-Value="showWelcome" />
                    <label class="form-check-label" for="show-welcome">Show this welcome page next time</label>
                </div>

                @if (!string.IsNullOrWhiteSpace(statusMessage))
                {
                    <div class="alert alert-info" role="alert">@statusMessage</div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" tabindex="1" disabled="@isSaving">Continue</button>
                    <button type="button" class="btn btn-outline-secondary" tabindex="2" @onclick="GoToLearn">Learn More</button>
                </div>
            </EditForm>
        </div>
    </div>

    @* TODO: No dedicated service method exists for the Welcome table (record source "Welcome"); create IWelcomeService for full parity. *@
</div>

@code {
    private WelcomeSettingsInput model = new();
    private bool showWelcome
    {
        get => model.ShowWelcome;
        set => model.ShowWelcome = value;
    }
    private string welcomeText = "Welcome to Northwind.";
    private string? learnText;
    private string? errorMessage;
    private string? statusMessage;
    private bool isLoading = true;
    private bool isSaving;
    private SystemSettings? showWelcomeSetting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var welcome = await Db.Welcome.FirstOrDefaultAsync();

            if (!string.IsNullOrWhiteSpace(welcome?.WelcomeText))
            {
                welcomeText = welcome.WelcomeText;
            }

            learnText = welcome?.Learn;

            var settings = await SystemSettingsService.GetSystemSettingsAsync();
            showWelcomeSetting = settings.FirstOrDefault(x => x.SettingID == (int)Generated_northwindstarteredit_efaf7961_a5a8_49a9_9cc8_803767fab1da.Models.Enums.SystemSettings.ShowWelcome);
            model.ShowWelcome = IsTrueValue(showWelcomeSetting?.SettingValue);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ContinueAsync()
    {
        statusMessage = null;
        isSaving = true;

        try
        {
            if (showWelcomeSetting is not null)
            {
                showWelcomeSetting.SettingValue = model.ShowWelcome ? "-1" : "0";
                await SystemSettingsService.UpdateAsync(showWelcomeSetting);
            }
            else
            {
                statusMessage = "ShowWelcome setting was not found; preference could not be saved.";
            }

            Navigation.NavigateTo("/main-menu");
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void GoToLearn()
    {
        Navigation.NavigateTo("/main-menu-learn");
    }

    private static bool IsTrueValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        if (bool.TryParse(value, out var boolValue))
        {
            return boolValue;
        }

        return value == "-1" || value == "1";
    }

}
